<mujoco model="kachaka">
  <compiler angle="radian"/>
  <option cone="elliptic"/>

    <default>
      <default class="kachaka_visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" density="0"/>
      </default>
      <default class="kachaka_collision">
        <geom group="3" type="capsule"/>
      </default>
    </default>

  <asset>
    <mesh name="body" content_type="model/stl" file="assets/body.stl"/>
    <mesh name="right_tire" content_type="model/stl" file="assets/right_tire.stl"/>
    <mesh name="left_tire" content_type="model/stl" file="assets/left_tire.stl"/>
    <mesh name="solenoid" content_type="model/stl" file="assets/solenoid.stl"/>
  </asset>

  <worldbody>
    <light name="spotlight_kachaka" mode="targetbodycom" target="kachaka_base_link" pos="0 0 2"/>
    <body name="kachaka_base_link">
      <inertial pos="0.0435 0.0 0.0475" mass="10.0" diaginertia="0.055521 0.132328 0.172808"/>
      <freejoint/>
      <geom pos="-0.15 -0.12 0" quat="1 0 0 0" rgba="0.2175 0.2355 0.246 1" mesh="body" class="kachaka_visual"/>
      <geom size="0.1935 0.12 0.0475" pos="0.0435 0 0.0475" type="box" rgba="0.2175 0.2355 0.246 1" class="kachaka_collision"/>
      <body name="base_r_drive_wheel_link" pos="0 -0.1 0.045">
        <inertial pos="0 0 0" quat="0.5 0.5 -0.5 0.5" mass="0.2" diaginertia="0.0002025 0.000111667 0.000111667"/>
        <joint name="base_r_drive_wheel_joint" pos="0 0 0" axis="0 1 0" actuatorfrcrange="-100 100" frictionloss="0.1" armature="0.01"/>
        <geom rgba="0.3 0.3 0.3 1" mesh="right_tire" class="kachaka_visual"/>
        <geom size="0.045 0.0125" quat="0.707107 0.707107 0 0" type="cylinder" rgba="0.3 0.3 0.3 1" class="kachaka_collision"/>
      </body>
      <body name="base_l_drive_wheel_link" pos="0 0.1 0.045">
        <inertial pos="0 0 0" quat="0.5 0.5 -0.5 0.5" mass="0.2" diaginertia="0.0002025 0.000111667 0.000111667"/>
        <joint name="base_l_drive_wheel_joint" pos="0 0 0" axis="0 1 0" actuatorfrcrange="-100 100" frictionloss="0.1" armature="0.01"/>
        <geom rgba="0.3 0.3 0.3 1" mesh="left_tire" class="kachaka_visual"/>
        <geom size="0.045 0.0125" quat="0.707107 0.707107 0 0" type="cylinder" rgba="0.3 0.3 0.3 1" class="kachaka_collision"/>
      </body>
      <body name="docking_link">
        <inertial pos="0 0 0.1075" quat="0.5 0.5 -0.5 0.5" mass="0.2" diaginertia="6.25e-05 3.5e-05 3.5e-05"/>
        <joint name="docking_joint" pos="0 0 0" axis="0 0 1" type="slide" range="0 0.012" actuatorfrcrange="-1 1"/>
        <geom rgba="0.2175 0.2355 0.246 1" mesh="solenoid" class="kachaka_visual"/>
        <geom size="0.025 0.0075" pos="0 0 0.1075" type="cylinder" rgba="0.2175 0.2355 0.246 1" class="kachaka_collision"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="base_r_drive_wheel" joint="base_r_drive_wheel_joint" kv="10" ctrlrange="-10 10" forcerange="-100 100"/>
    <velocity name="base_l_drive_wheel" joint="base_l_drive_wheel_joint" kv="10" ctrlrange="-10 10" forcerange="-100 100"/>
    <position name="docking" joint="docking_joint" kp="100" ctrlrange="0 0.012" forcerange="-1 1"/>
  </actuator>
</mujoco>
